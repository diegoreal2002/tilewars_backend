{
  "kind": "collectionType",
  "collectionName": "usuas",
  "info": {
    "singularName": "usua",
    "pluralName": "usuas",
    "displayName": "Player Profile",
    "description": "Perfil de juego editable desde Strapi"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "usua_userna": {
      "type": "string",
      "required": true
    },
    "usua_email": {
      "type": "email",
      "required": true
    },
    "usua_passwo": {
      "type": "password"
    },
    "usua_idgoog": {
      "type": "string"
    },
    "usua_nocoin": {
      "type": "integer",
      "required": true,
      "default": 0,
      "min": 0
    },
    "usua_verifi": {
      "type": "boolean",
      "default": false
    },
    "usua_create": {
      "type": "date",
      "required": true
    },
    "usua_avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "user": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
